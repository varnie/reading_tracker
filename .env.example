# =============================================================================
# DEVELOPMENT ENVIRONMENT
# =============================================================================

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=v1
LOG_LEVEL=INFO

# Database (local)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reading_tracker
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis (local)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# JWT - IMPORTANT: Change this in production!
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# Argon2 - Increase cost in production for better security
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Email (SMTP) - Leave EMAIL_ENABLED=false for development
EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@readingtracker.app
SMTP_FROM_NAME=Reading Tracker
SMTP_TLS=true

# Celery (local)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# PRODUCTION VARIABLES (for docker-compose.prod.yml)
# Copy to .env and fill in secure values
# =============================================================================

# Generate secure values with:
#   openssl rand -hex 32

# JWT Secret (REQUIRED)
# JWT_SECRET_KEY=your-super-secure-64-char-hex-key-here

# PostgreSQL
# POSTGRES_DB=reading_tracker
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=generate-a-secure-password
# POSTGRES_PORT=5432

# Redis
# REDIS_PASSWORD=generate-a-secure-password
# REDIS_PORT=6379

# API
# API_PORT=8000

# Logging
# LOG_LEVEL=WARNING

# Resource Limits
# POSTGRES_CPU_LIMIT=1
# POSTGRES_MEMORY_LIMIT=512M
# REDIS_CPU_LIMIT=0.5
# REDIS_MEMORY_LIMIT=256M
# API_CPU_LIMIT=2
# API_MEMORY_LIMIT=512M
# WORKER_CPU_LIMIT=1
# WORKER_MEMORY_LIMIT=512M
# BEAT_CPU_LIMIT=0.5
# BEAT_MEMORY_LIMIT=256M

# Database Pool
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20

# Rate Limiting
# RATE_LIMIT_PER_MINUTE=100
